{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "main": "src/app.ts",
  "imports": {
    "#@/*": "./src/*"
  },
  "scripts": {
    "postinstall": "check-node-version --package",
    "start": "tsx ./src/bin/www.ts",
    "debug": "tsx --inspect ./src/bin/www.ts --log-level debug",
    "dev": "tsx watch ./src/bin/www.ts --log-level debug",
    "build": "tsc --noEmit",
    "lint": "eslint ./src --fix",
    "lint:ci": "eslint ./src",
    "test": "mocha --require tsx/cjs 'test/unit/**/*.{js,ts}'"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "!*.{js,ts}": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "@elastic/elasticsearch": "7.4.0",
    "aws-sdk": "^2.510.0",
    "axios": "^1.13.5",
    "body-parser": "^1.18.3",
    "check-node-version": "^4.0.1",
    "compression": "^1.7.4",
    "dotenv": "^8.0.0",
    "express": "~4.16.0",
    "express-async-handler": "^1.1.4",
    "express-http-proxy": "^1.6.0",
    "express-jwt": "8.4.1",
    "express-session": "^1.17.1",
    "http-errors": "~1.6.2",
    "lodash": "^4.17.21",
    "lru-cache": "^11.2.6",
    "moment": "^2.22.2",
    "morgan": "~1.9.1",
    "nocache": "^2.0.0",
    "sharp": "0.34.5",
    "uuid": "^8.3.2",
    "winston": "^3.1.0",
    "yargs": "^17.1.1"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.24",
    "@types/mocha": "^10.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.2",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "chai": "^4.2.0",
    "eslint": "^8.30.0",
    "eslint-config-prettier": "^8.5.0",
    "mocha": "^5.2.0",
    "nodemon": "^2.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
